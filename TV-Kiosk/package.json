{
  "name": "lab-tv-kiosk",
  "version": "1.0.0",
  "description": "Jharkhand State Diagnostic Services — Lab Queue & Kiosk Display",
  "main": "main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"vite --config renderer/vite.config.js\" \"wait-on http://localhost:5174 && electron .\"",
    "start": "electron .",
    "build:ui": "vite build --config renderer/vite.config.js",
    "dist:win": "npm run build:ui && electron-builder --win",
    "dist:mac": "npm run build:ui && electron-builder --mac"
  },
  "build": {
    "appId": "com.poxiatechnologies.labtvkiosk",
    "productName": "Lab TV Kiosk",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "build/icon.icns"
    },
    "files": [
      "main/**/*",
      "dist/**/*",
      "build/**/*",
      "package.json"
    ],
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "lucide-react": "^1.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.0.0",
    "vite": "^6.0.0",
    "wait-on": "^9.0.0"
  }
}
